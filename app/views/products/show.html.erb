<div class="bg-white min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-8">
      <a href="<%= root_path %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Voltar para a vitrine</a>
    </div>

    <div class="lg:grid lg:grid-cols-2 lg:gap-x-8 lg:items-start">
      
      <div class="flex flex-col">
        <div class="w-full aspect-w-1 aspect-h-1 bg-gray-100 rounded-lg overflow-hidden shadow-sm">
          <% first_color = @product.product_colors.first %>
          <img src="<%= first_color&.image_url %>" alt="<%= @product.name %>" class="w-full h-full object-center object-cover">
        </div>
      </div>

      <div class="mt-10 px-4 sm:px-0 sm:mt-16 lg:mt-0">
        <div class="space-y-4">
          <span class="text-xs font-bold uppercase tracking-wider bg-gray-100 text-gray-800 px-3 py-1 rounded-full"><%= @product.category %></span>
          <h1 class="text-3xl font-extrabold tracking-tight text-gray-900"><%= @product.name %></h1>
          
          <div class="mt-3">
            <h2 class="sr-only">Informações do produto</h2>
            <p class="text-3xl text-gray-900 font-bold">
              <span class="text-sm font-normal text-gray-400">A partir de</span>
              R$ <%= number_with_precision(@product.starting_price, precision: 2, separator: ',') %>
            </p>
          </div>

          <div class="mt-6">
            <h3 class="sr-only">Descrição</h3>
            <div class="text-base text-gray-700 space-y-6">
              <p><%= @product.description %></p>
            </div>
          </div>

          <hr class="my-6 border-gray-200">

          <div>
            <h3 class="text-sm font-medium text-gray-900 mb-4">Opções Disponíveis no Estoque:</h3>
            <div class="space-y-4">
              <% @product.product_colors.each do |color| %>
                <div class="bg-gray-50 p-4 rounded-lg border border-gray-100">
                  <h4 class="text-sm font-bold text-gray-800 flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-indigo-600"></span>
                    Cor: <%= color.color_name %>
                  </h4>
                  <ul class="mt-2 space-y-2 pl-5 list-disc text-sm text-gray-600">
                    <% color.variants.each do |variant| %>
                      <li>
                        Tamanho: <strong class="text-gray-900"><%= variant.size %></strong> - 
                        Preço: <strong class="text-gray-900">R$ <%= number_with_precision(variant.price, precision: 2, separator: ',') %></strong> 
                        <% if variant.stock > 0 %>
                          <span class="text-green-600 font-medium">(<%= variant.stock %> disponíveis)</span>
                        <% else %>
                          <span class="text-red-500 font-medium italic">(Esgotado)</span>
                        <% end %>
                        <span class="text-xs text-gray-400 ml-2">[SKU: <%= variant.sku %>]</span>
                      </li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>